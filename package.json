{
  "name": "vantagepoint-command-core",
  "version": "1.0.0",
  "description": "Sovereign Proxy for VantagePoint Command Core",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "main": "dist/MeshOrchestrator.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/boot-mesh.js",
    "start:proxy": "node dist/SovereignProxy.js",
    "test": "vitest run",
    "showcase": "npm run dev --workspace=packages/spatial-war-room -- --open",
    "validate:pr": "node scripts/validate-pr.mjs",
    "validate:chairs": "npm run build && node scripts/validate-all-chairs.mjs",
    "smoke:local-state-ingest": "npm run build && node scripts/local-state-ingest-smoke.mjs",
    "validate:real-runtimes": "npm run build && node scripts/real-runtime-smoke.mjs --agents nyx-codex,shaev --require-real --timeout-ms 180000"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleks7732/Kovael.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aleks7732/Kovael/issues"
  },
  "homepage": "https://github.com/aleks7732/Kovael#readme",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
